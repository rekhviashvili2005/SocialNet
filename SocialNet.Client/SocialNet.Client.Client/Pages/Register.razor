@page "/register"
@rendermode InteractiveWebAssembly
@using SocialNet.Client.Client.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<h3>რეგისტრაცია</h3>

<div>
    <input @bind="userName" placeholder="მომხმარებლის სახელი" />
</div>
<div>
    <input @bind="displayName" placeholder="სახელი და გვარი" />
</div>
<div>
    <input @bind="email" placeholder="Email" type="email" />
</div>
<div>
    <input @bind="password" placeholder="პაროლი" type="password" />
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <p style="color:red">@errorMessage</p>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <p style="color:green">@successMessage</p>
}

<button @onclick="HandleRegister">რეგისტრაცია</button>
<br />
<a href="/login">უკვე გაქვს ანგარიში? შედი!</a>

@code {
    private string userName = "";
    private string displayName = "";
    private string email = "";
    private string password = "";
    private string errorMessage = "";
    private string successMessage = "";

    private async Task HandleRegister()
    {
        var result = await AuthService.RegisterAsync(
            userName, email, password, displayName);

        if (!result)
        {
            errorMessage = "რეგისტრაცია ვერ მოხერხდა!";
            return;
        }

        successMessage = "რეგისტრაცია წარმატებულია!";
        Navigation.NavigateTo("/login");
    }
}