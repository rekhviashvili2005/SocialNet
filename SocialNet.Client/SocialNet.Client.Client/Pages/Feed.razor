    //         uploadedImageUrls = new();
    //     }
    //     finally
    //     {
    //         isUploading = false;
    //         StateHasChanged();
    //     }
    // }

    private async Task OnImagesSelected(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles(10);
        if (!files.Any()) return;

        isUploading = true;
        StateHasChanged();

        try
        {
            foreach (var file in files)
            {
                selectedImageNames.Add(file.Name); // ახალი სახელები ემატება
                using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                var url = await PostService.UploadImageAsync(stream, file.Name);
                if (url != null)
                    uploadedImageUrls.Add(url); // ახალი URL ემატება, არ ენაცვლება
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Upload error: {ex.Message}");
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }

    private void RemoveImage(int index)
    {
        if (index < selectedImageNames.Count)
            selectedImageNames.RemoveAt(index);
        if (index < uploadedImageUrls.Count)
            uploadedImageUrls.RemoveAt(index);
        StateHasChanged();
    }

    private async Task OnSearchInput()
    {
        searchCts?.Cancel();
        searchCts?.Dispose();
        searchCts = new System.Threading.CancellationTokenSource();
        var token = searchCts.Token;

        await Task.Delay(300);
        if (token.IsCancellationRequested) return;

        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            searchResults = new();
            StateHasChanged();
            return;
        }

        try
        {
            var results = await Http.GetFromJsonAsync<List<UserSearchDto>>($"api/Users/search?query={searchQuery}");
            if (!token.IsCancellationRequested)
            {
                searchResults = results ?? new();
                StateHasChanged();
            }
        }
        catch
        {
            searchResults = new();
        }
    }

    private void GoToProfile(string username)
    {
        searchQuery = "";
        searchResults = new();
        Navigation.NavigateTo($"/profile/{username}");
    }

    private void ToggleHashtag(string tag)
    {
        if (selectedHashtags.Contains(tag))
            selectedHashtags.Remove(tag);
        else
            selectedHashtags.Add(tag);

        showHashtagWarning = false;
    }

    private async Task FilterByHashtag(string? tag)
    {
        activeFilter = tag;

        if (tag == null)
            posts = await PostService.GetAllPostsAsync();
        else
            posts = await PostService.GetPostsByHashtagAsync(tag);

        if (posts != null)
        {
            foreach (var post in posts)
            {
                if (!newComments.ContainsKey(post.Id))
                    newComments[post.Id] = "";
            }
        }
    }

    private async Task CreatePost()
    {
        if (string.IsNullOrEmpty(currentUsername))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (string.IsNullOrWhiteSpace(newPostContent)) return;

        if (!selectedHashtags.Any())
        {
            showHashtagWarning = true;
            return;
        }

        showHashtagWarning = false;

        var result = await PostService.CreatePostAsync(
            newPostContent,
            selectedHashtags.ToList(),
            null,
            uploadedImageUrls
        );

        if (result)
        {
            newPostContent = "";
            selectedHashtags.Clear();
            selectedImageNames = new();
            uploadedImageUrls = new();
            posts = await PostService.GetAllPostsAsync();
            if (posts != null)
            {
                foreach (var post in posts)
                {
                    if (!newComments.ContainsKey(post.Id))
                        newComments[post.Id] = "";
                }
            }
        }
    }

    private async Task ToggleLike(Guid postId)
    {
        if (string.IsNullOrEmpty(currentUsername))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        try
        {
            var result = await PostService.ToggleLikeAsync(postId);
            if (result)
            {
                var post = posts?.FirstOrDefault(p => p.Id == postId);
                if (post != null)
                {
                    if (post.IsLikedByCurrentUser)
                    {
                        post.LikesCount--;
                        post.IsLikedByCurrentUser = false;
                    }
                    else
                    {
                        post.LikesCount++;
                        post.IsLikedByCurrentUser = true;
                    }
                }
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Like error: {ex.Message}");
        }
    }

    private async Task ToggleComments(Guid postId)
    {
        if (string.IsNullOrEmpty(currentUsername))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (!newComments.ContainsKey(postId))
            newComments[postId] = "";

        if (openComments.Contains(postId))
            openComments.Remove(postId);
        else
        {
            openComments.Add(postId);
            if (!comments.ContainsKey(postId))
            {
                var result = await PostService.GetCommentsAsync(postId);
                comments[postId] = result ?? new();
            }
        }
    }

    // private async Task AddComment(Guid postId)
    // {
    //     if (string.IsNullOrEmpty(currentUsername))
    //     {
    //         Navigation.NavigateTo("/login");
    //         return;
    //     }
    //     if (!newComments.ContainsKey(postId)) return;
    //     if (string.IsNullOrWhiteSpace(newComments[postId]) && !commentImageUrls.ContainsKey(postId)) return;

    //     var imageUrl = commentImageUrls.ContainsKey(postId) ? commentImageUrls[postId] : null;
    //     var result = await PostService.AddCommentAsync(postId, newComments[postId] ?? "", imageUrl);
    //     if (result)
    //     {
    //         newComments[postId] = "";
    //         commentImageUrls.Remove(postId);
    //         var updated = await PostService.GetCommentsAsync(postId);
    //         comments[postId] = updated ?? new();
    //         StateHasChanged();
    //     }
    // }
    private async Task AddComment(Guid postId)
    {
        if (string.IsNullOrEmpty(currentUsername))
        {
            Navigation.NavigateTo("/login");
            return;
        }
        if (!newComments.ContainsKey(postId)) return;

        var imageUrls = commentImageUrls.ContainsKey(postId) ? commentImageUrls[postId] : new();
        if (string.IsNullOrWhiteSpace(newComments[postId]) && !imageUrls.Any()) return;

        var result = await PostService.AddCommentAsync(postId, newComments[postId] ?? "", imageUrls);
        if (result)
        {
            newComments[postId] = "";
            commentImageUrls.Remove(postId);
            var updated = await PostService.GetCommentsAsync(postId);
            comments[postId] = updated ?? new();
            StateHasChanged();
        }
    }



    private string activeTab = "all";

    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        activeFilter = null;

        if (tab == "following")
        {
            if (string.IsNullOrEmpty(currentUsername))
            {
                Navigation.NavigateTo("/login");
                return;
            }
            posts = await PostService.GetFollowingPostsAsync();
        }
        else
        {
            posts = await PostService.GetFeedPostsAsync();
        }

        if (posts != null)
        {
            foreach (var post in posts)
            {
                if (!newComments.ContainsKey(post.Id))
                    newComments[post.Id] = "";
            }
        }
        StateHasChanged();
    }

    private string? expandedCommentImage = null;
    private Dictionary<Guid, List<string>> commentImageUrls = new();
    // private Dictionary<Guid, string> commentImageUrls = new();
    private Dictionary<Guid, bool> commentImageUploading = new();

    // private async Task OnCommentImageSelected(InputFileChangeEventArgs e, Guid postId)
    // {
    //     var file = e.File;
    //     commentImageUploading[postId] = true;
    //     StateHasChanged();

    //     using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
    //     var url = await PostService.UploadImageAsync(stream, file.Name);
    //     if (url != null)
    //         commentImageUrls[postId] = url;

    //     commentImageUploading[postId] = false;
    //     StateHasChanged();
    // }
    private async Task OnCommentImageSelected(InputFileChangeEventArgs e, Guid postId)
    {
        var files = e.GetMultipleFiles(5);
        commentImageUploading[postId] = true;
        StateHasChanged();

        if (!commentImageUrls.ContainsKey(postId))
            commentImageUrls[postId] = new();

        try
        {
            foreach (var file in files)
            {
                using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                var url = await PostService.UploadImageAsync(stream, file.Name);
                if (url != null)
                    commentImageUrls[postId].Add(url);
            }
        }
        finally
        {
            commentImageUploading[postId] = false;
            StateHasChanged();
        }
    }
}

