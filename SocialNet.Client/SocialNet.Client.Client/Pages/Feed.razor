@page "/feed"
@rendermode InteractiveWebAssembly
@using SocialNet.Client.Client.Services
@using Microsoft.AspNetCore.Components.Forms
@inject PostService PostService
@inject NavigationManager Navigation
@inject LocalStorageService LocalStorage
@inject HttpClient Http
@inject FollowService FollowService
@implements IDisposable

<div class="search-bar-card">
    <div class="search-input-row">
        <input @oninput="e => { searchQuery = e.Value?.ToString() ?? string.Empty; _ = OnSearchInput(); }"
               value="@searchQuery"
               placeholder="მომხმარებლის ძიება..." />
    </div>

    @if (searchResults.Any())
    {
        <div class="search-results">
            @foreach (var user in searchResults)
            {
                <div class="search-result-item" @onclick="() => GoToProfile(user.UserName)">
                    <span class="search-result-name">@user.DisplayName</span>
                    <span class="search-result-username">@("@")@user.UserName</span>
                </div>
            }
        </div>
    }
</div>

<div class="composer-card">
    <textarea @bind="newPostContent" placeholder="რაზე ფიქრობ?"></textarea>

    <div class="image-upload-section" style="margin-top:0.7rem;">
        <InputFile OnChange="OnImagesSelected" accept="image/*" multiple
                   id="imageInput"
                   style="display:none;" />
        <label for="imageInput" class="btn-pill btn-pill-outline" style="cursor:pointer; display:inline-block;">
            🖼️ სურათების დამატება
        </label>

        @if (isUploading)
        {
            <span style="font-size:0.85rem; color:var(--color-primary); margin-left:0.5rem;">
                ⏳ იტვირთება...
            </span>
        }

        @if (selectedImageNames.Any())
        {
            <div style="margin-top:0.5rem; display:flex; flex-wrap:wrap; gap:0.4rem;">
                @for (int i = 0; i < selectedImageNames.Count; i++)
                {
                    var index = i;
                    <span style="font-size:0.8rem; color:var(--color-text-muted); background:var(--color-surface-2); padding:0.2rem 0.6rem; border-radius:999px; display:flex; align-items:center; gap:0.3rem;">
                        ✅ @selectedImageNames[index]
                        <button @onclick="() => RemoveImage(index)"
                                style="background:none; border:none; color:#F43F5E; cursor:pointer; font-size:0.9rem; padding:0; line-height:1;">
                            ✕
                        </button>
                    </span>
                }
            </div>
        }
    </div>

    <div class="hashtag-selector">
        <p>ჰეშთეგები აირჩიე:</p>
        <div class="hashtag-options">
            @foreach (var tag in availableHashtags)
            {
                <button class="btn-pill @(selectedHashtags.Contains(tag) ? "btn-pill-primary" : "btn-pill-outline")"
                        @onclick="() => ToggleHashtag(tag)">
                    #@tag
                </button>
            }
        </div>
    </div>

    @if (showHashtagWarning)
    {
        <p style="color: red; font-size: 0.85rem; margin: 4px 0 0 4px;">⚠️ პოსტის დადება ჰეშთეგის გარეშე არ შეიძლება!</p>
    }

    <div class="composer-footer">
        <button class="btn-pill btn-pill-primary" @onclick="CreatePost">გამოქვეყნება</button>
    </div>
</div>

<div class="feed-tabs">
    <button class="feed-tab @(activeTab == "all" ? "feed-tab-active" : "")"
            @onclick='() => SwitchTab("all")'>
        All Posts
    </button>
    <button class="feed-tab @(activeTab == "following" ? "feed-tab-active" : "")"
            @onclick='() => SwitchTab("following")'>
        Following
    </button>
</div>


<div class="hashtag-filter">
    <p>ფილტრი:</p>
    <div class="hashtag-options">
        <button class="btn-pill @(activeFilter == null ? "btn-pill-primary" : "btn-pill-outline")"
                @onclick="() => FilterByHashtag(null)">
            ყველა
        </button>
        @foreach (var tag in availableHashtags)
        {
            <button class="btn-pill @(activeFilter == tag ? "btn-pill-primary" : "btn-pill-outline")"
                    @onclick="() => FilterByHashtag(tag)">
                #@tag
            </button>
        }
    </div>
</div>


@if (posts == null)
{
    <p>იტვირთება...</p>
}
else if (!posts.Any())
{
    <p>პოსტები არ არის!</p>
}
else
{
    @foreach (var post in posts)
    {
        <div class="post-card">
            <div class="post-card-header">
                <div style="display:flex; align-items:center; gap:0.6rem;">
                    <span class="post-author" style="cursor:pointer;"
                          @onclick="() => { if (!string.IsNullOrEmpty(post.UserName)) GoToProfile(post.UserName); }">
                        @post.UserName
                    </span>
                    @if (!string.IsNullOrEmpty(currentUsername) && post.UserName != currentUsername)
                    {
                        <button class="btn-pill @(followStates.ContainsKey(post.AuthorId) && followStates[post.AuthorId] ? "btn-pill-following" : "btn-pill-follow")"
                                style="padding:0.25rem 0.7rem; font-size:0.78rem;"
                                @onclick="() => ToggleFollowFromFeed(post.AuthorId)">
                            @(followStates.ContainsKey(post.AuthorId) && followStates[post.AuthorId] ? "Unfollow" : "Follow")
                        </button>
                    }
                </div>
                <span class="post-time">@post.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
            </div>




            <p class="post-content">@post.Content</p>

            @if (post.ImageUrls.Any())
            {
                <div class="post-images">
                    @foreach (var imgUrl in post.ImageUrls)
                    {
                        <img src="@imgUrl" class="post-image" alt="post image" />
                    }
                </div>
            }
            else if (!string.IsNullOrEmpty(post.ImageUrl))
            {
                <img src="@post.ImageUrl" class="post-image" alt="post image" />
            }

            @if (post.Hashtags.Any())
            {
                <div class="post-hashtags">
                    @foreach (var tag in post.Hashtags)
                    {
                        <span class="hashtag-badge" @onclick="() => FilterByHashtag(tag)">#@tag</span>
                    }
                </div>
            }

            <div class="post-actions">
                <button class="btn-pill @(post.IsLikedByCurrentUser ? "btn-pill-liked" : "btn-pill-outline")"
                        @onclick="() => ToggleLike(post.Id)">
                    ❤️ @post.LikesCount ლაიქი
                </button>
                <button class="btn-pill btn-pill-outline" @onclick="() => ToggleComments(post.Id)">💬 კომენტარი</button>
            </div>




            @if (openComments.Contains(post.Id))
            {
                <div class="comments-section">
                    @if (comments.ContainsKey(post.Id))
                    {
                        @foreach (var comment in comments[post.Id])
                        {
                            @* <div class="comment-item">
                                <span class="comment-author">@comment.UserName:</span>
                                <span>@comment.Content</span>
                                @if (!string.IsNullOrEmpty(comment.ImageUrl))
                                {
                                    <div style="margin-top:0.4rem;">
                                        <img src="@comment.ImageUrl"
                                             style="max-height:60px; max-width:80px; border-radius:6px; cursor:pointer; object-fit:cover;"
                                             @onclick="@(() => { expandedCommentImage = comment.ImageUrl; StateHasChanged(); })" />
                                    </div>
                                }
                            </div> *@
                            <div class="comment-item">
                                <span class="comment-author">@comment.UserName:</span>
                                <span>@comment.Content</span>
                                @if (comment.ImageUrls.Any())
                                {
                                    <div style="display:flex; flex-wrap:wrap; gap:0.4rem; margin-top:0.4rem;">
                                        @foreach (var imgUrl in comment.ImageUrls)
                                        {
                                            <img src="@imgUrl"
                                                 style="max-height:60px; max-width:80px; border-radius:6px; cursor:pointer; object-fit:cover;"
                                                 @onclick="@(() => { expandedCommentImage = imgUrl; StateHasChanged(); })" />
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                    <div class="comment-input-row">
                        <input value="@(newComments.ContainsKey(post.Id) ? newComments[post.Id] : "")"
                               @onchange="e => newComments[post.Id] = e.Value?.ToString() ?? string.Empty"
                               placeholder="კომენტარი..." />
                        <InputFile id="@($"comment-img-{post.Id}")"
                                   OnChange="e => OnCommentImageSelected(e, post.Id)"
                                   accept="image/*"
                                   style="display:none;" />
                        <label for="@($"comment-img-{post.Id}")" class="btn-pill btn-pill-outline" style="cursor:pointer;">
                            🖼️
                        </label>
                        <button class="btn-pill btn-pill-primary" @onclick="() => AddComment(post.Id)">გაგზავნა</button>
                    </div>
                    @if (commentImageUploading.ContainsKey(post.Id) && commentImageUploading[post.Id])
                    {
                        <div style="margin-top:0.4rem; color:var(--color-text-muted); font-size:0.85rem;">
                            ⏳ იტვირთება...
                        </div>
                    }
                    @* @if (commentImageUrls.ContainsKey(post.Id) && !string.IsNullOrEmpty(commentImageUrls[post.Id]))
                    {
                        <div style="margin-top:0.4rem; position:relative; display:inline-block;">
                            <img src="@commentImageUrls[post.Id]" style="max-height:100px; border-radius:8px;" />
                            <button @onclick="() => commentImageUrls.Remove(post.Id)"
                                    style="position:absolute; top:-6px; right:-6px; background:#F43F5E; color:white; border:none; border-radius:50%; width:20px; height:20px; cursor:pointer; font-size:0.7rem;">
                                ✕
                            </button>
                        </div>
                    } *@
                    @if (commentImageUrls.ContainsKey(post.Id) && commentImageUrls[post.Id].Any())
                    {
                        <div style="display:flex; flex-wrap:wrap; gap:0.4rem; margin-top:0.4rem;">
                            @foreach (var (url, index) in commentImageUrls[post.Id].Select((u, i) => (u, i)))
                            {
                                <div style="position:relative; display:inline-block;">
                                    <img src="@url" style="max-height:100px; border-radius:8px;" />
                                    <button @onclick="() => commentImageUrls[post.Id].RemoveAt(index)"
                                            style="position:absolute; top:-6px; right:-6px; background:#F43F5E; color:white; border:none; border-radius:50%; width:20px; height:20px; cursor:pointer; font-size:0.7rem;">
                                        ✕
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(expandedCommentImage))
            {
                <div style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:9999; display:flex; align-items:center; justify-content:center;"
                     @onclick="@(() => { expandedCommentImage = null; StateHasChanged(); })">
                    <img src="@expandedCommentImage" style="max-width:90%; max-height:90%; border-radius:12px;" />
                </div>
            }


        </div>
    }
}

@code {
    private List<PostDto>? posts;
    private string newPostContent = "";
    private HashSet<Guid> openComments = new();
    private Dictionary<Guid, List<CommentDto>> comments = new();
    private Dictionary<Guid, string> newComments = new();
    private string? currentUsername;
    private string? currentUserId;
    private string? activeFilter = null;
    private bool showHashtagWarning = false;
    private HashSet<string> selectedHashtags = new();
    private Dictionary<string, bool> followStates = new();

    private string searchQuery = "";
    private List<UserSearchDto> searchResults = new();
    private System.Threading.CancellationTokenSource? searchCts;

    private List<string> selectedImageNames = new();
    private List<string> uploadedImageUrls = new();
    private bool isUploading = false;

    private List<string> availableHashtags = new()
    {
        "Football", "Basketball", "Tennis", "Formula1",
        "MMA", "Rugby", "Volleyball", "Handball"
    };

    public void Dispose()
    {
        searchCts?.Cancel();
        searchCts?.Dispose();
    }

    protected override async Task OnInitializedAsync()
    {
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            currentUsername = await LocalStorage.GetItemAsync("username");
            currentUserId = await LocalStorage.GetItemAsync("userId");
            //posts = await PostService.GetAllPostsAsync();
             posts = await PostService.GetFeedPostsAsync();


            if (posts != null)
            {
                foreach (var post in posts)
                {
                    if (!newComments.ContainsKey(post.Id))
                        newComments[post.Id] = "";
                }

                if (!string.IsNullOrEmpty(currentUserId))
                {
                    var authorIds = posts.Select(p => p.AuthorId).Distinct().ToList();
                    foreach (var authorId in authorIds)
                    {
                        if (!string.IsNullOrEmpty(authorId) && authorId != currentUserId)
                        {
                            var isFollowing = await FollowService.IsFollowingAsync(authorId);
                            followStates[authorId] = isFollowing;
                        }
                    }
                }
            }
            StateHasChanged();
        }
    }

    private async Task ToggleFollowFromFeed(string authorId)
    {
        if (string.IsNullOrEmpty(currentUsername))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (followStates.ContainsKey(authorId) && followStates[authorId])
        {
            await FollowService.UnFollowAsync(authorId);
            followStates[authorId] = false;
        }
        else
        {
            await FollowService.FollowAsync(authorId);
            followStates[authorId] = true;
        }
        StateHasChanged();
    }

    // private async Task OnImagesSelected(InputFileChangeEventArgs e)
    // {
