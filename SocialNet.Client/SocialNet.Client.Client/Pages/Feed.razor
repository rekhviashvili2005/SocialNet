    //     if (!files.Any()) return;

    //     selectedImageNames = files.Select(f => f.Name).ToList();
    //     isUploading = true;
    //     StateHasChanged();

    //     try
    //     {
    //         uploadedImageUrls = new();
    //         foreach (var file in files)
    //         {
    //             using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
    //             var url = await PostService.UploadImageAsync(stream, file.Name);
    //             if (url != null)
    //                 uploadedImageUrls.Add(url);
    //         }
    //     }
    //     catch (Exception ex)
    //     {
    //         Console.WriteLine($"Upload error: {ex.Message}");
