@page "/profile/{username}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@using SocialNet.Client.Client.Services
@using Microsoft.AspNetCore.Components.Web

@inject HttpClient Http
@inject NavigationManager Navigation
@inject FollowService FollowService
@inject LocalStorageService LocalStorage
@inject PostService PostService

<h3>პროფილი</h3>

@if (!isLoaded)
{
    <p>იტვირთება...</p>
}
else if (profile == null)
{
    <p>მომხმარებელი ვერ მოიძებნა!</p>
}
else
{
    <div class="profile-card">
        <div class="profile-name">
            @profile.DisplayName
        </div>

        <div class="profile-username">
            @("@")@profile.UserName
        </div>

        @if (!string.IsNullOrEmpty(profile.Bio))
        {
            <p class="profile-bio">
                @profile.Bio
            </p>
        }

        <div class="profile-stats">
            <span>
                <strong>@profile.PostsCount</strong> პოსტი
            </span>
            <span>
                <strong>@followersCount</strong> ფოლოუერი
            </span>
            <span>
                მიჰყვება
                <strong>@followingCount</strong>
            </span>
        </div>

        @if (isOwnProfile)
        {
            <button class="btn-pill btn-pill-follow" @onclick="EditMode">
                @(isEditing ? "გაუქმება" : "პროფილის რედაქტირება")
            </button>

            @if (isEditing)
            {
                <div style="margin-top:1rem;">
                    <input @bind="editDisplayName" placeholder="სახელი" style="display:block;margin-bottom:10px;" />
                    <textarea @bind="editBio" placeholder="Bio" style="display:block;margin-bottom:10px;"></textarea>
                    <button class="btn-pill btn-pill-follow" @onclick="SaveProfile">
                        შენახვა
                    </button>
                </div>
            }
        }
        else if (!string.IsNullOrEmpty(currentUserId))
        {
            <button class="btn-pill @(isFollowing ? "btn-pill-following" : "btn-pill-follow")" @onclick="ToggleFollow">
                @(isFollowing ? "Unfollow" : "Follow")
            </button>
        }
    </div>

    <h4 class="section-title">პოსტები:</h4>

    @foreach (var post in posts)
    {
        <div class="post-card">
            <div style="display:flex; justify-content:space-between; align-items:center; padding:1rem 1.2rem 0.5rem;">
                <span style="font-weight:600; font-size:15px; color:#fff;">@profile.DisplayName</span>
                <div style="display:flex; align-items:center; gap:0.5rem;">
                    <span style="font-size:12px; color:rgba(255,255,255,0.4);">@post.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    @if (isOwnProfile)
                    {
                        <button class="btn-pill btn-pill-outline"
                                style="color:#F43F5E; border-color:#F43F5E; padding:0.2rem 0.7rem; font-size:0.8rem;"
                                @onclick="() => DeletePost(post.Id)">
                            🗑️
                        </button>
                    }
                </div>
            </div>

            <p class="post-content" style="margin:0; padding:0 1.2rem 0.75rem; color:rgba(255,255,255,0.85);">
                @post.Content
            </p>

            @if (!string.IsNullOrEmpty(post.ImageUrl))
            {
                <img src="@post.ImageUrl" class="post-image" alt="post image" />
            }

            @if (post.Hashtags.Any())
            {
                <div class="post-hashtags">
                    @foreach (var tag in post.Hashtags)
                    {
                        <span class="hashtag-badge">#@tag</span>
                    }
                </div>
            }

            <div class="post-actions">
                <button class="btn-pill @(post.IsLikedByCurrentUser ? "btn-pill-liked" : "btn-pill-outline")"
                        @onclick="() => LikePost(post)">
                    ❤️ @post.LikesCount
                </button>
                <button class="btn-pill btn-pill-outline" @onclick="() => OpenComments(post)">
                    💬 კომენტარი
                </button>
            </div>

            @if (selectedPostId == post.Id)
            {
                <div class="comments-section">
                    @foreach (var c in comments)
                    {
                        <div class="comment-item">
                            <span class="comment-author">@c.UserName:</span>
                            <span>@c.Content</span>
                        </div>
                    }
                    <div class="comment-input-row">
                        <input @bind="commentText" @onkeydown="HandleCommentKey" placeholder="დაწერე კომენტარი..." />
                        <button class="btn-pill btn-pill-primary" @onclick="() => AddComment(post.Id)">
                            გაგზავნა
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    <h4 class="section-title">ფოლოუერები:</h4>

    @foreach (var f in followers)
    {
        <div class="follow-list-item">@f</div>
    }

    <h4 class="section-title">მიჰყვება:</h4>

    @foreach (var f in following)
    {
        <div class="follow-list-item">@f</div>
    }
}

@code {
    [Parameter]
    public string? username { get; set; }

    private UserProfileDto? profile;
    private List<PostDto> posts = new();
    private bool isLoaded = false;
    private bool isFollowing = false;
    private int followersCount = 0;
    private int followingCount = 0;
    private List<string> followers = new();
    private List<string> following = new();
    private string? currentUserId;
    private bool isOwnProfile = false;
    private bool isEditing = false;
    private string editDisplayName = "";
    private string editBio = "";
    private Guid? selectedPostId;
    private string commentText = "";
    private List<CommentDto> comments = new();

    protected override async Task OnInitializedAsync()
    {
        if (username == null) return;

        try
        {
            currentUserId = await LocalStorage.GetItemAsync("userId");
            var token = await LocalStorage.GetItemAsync("token");

            var profileTask = Http.GetFromJsonAsync<UserProfileDto>($"api/Users/{username}");

            var postsRequest = new HttpRequestMessage(HttpMethod.Get, $"api/Users/{username}/posts");
            if (token != null)
                postsRequest.Headers.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var postsResponse = await Http.SendAsync(postsRequest);
            var postsTask = postsResponse.Content.ReadFromJsonAsync<List<PostDto>>();

            await Task.WhenAll(profileTask, postsTask);

            profile = profileTask.Result;
            posts = postsTask.Result ?? new();

            if (profile != null)
            {
                var isFollowingTask = FollowService.IsFollowingAsync(profile.Id);
                var followersCountTask = FollowService.GetFollowersCountAsync(profile.Id);
                var followingCountTask = FollowService.GetFollowingCountAsync(profile.Id);
                var followersTask = FollowService.GetFollowersAsync(profile.Id);
                var followingTask = FollowService.GetFollowingAsync(profile.Id);

                await Task.WhenAll(
                    isFollowingTask,
                    followersCountTask,
                    followingCountTask,
                    followersTask,
                    followingTask
                );

                isFollowing = isFollowingTask.Result;
                followersCount = followersCountTask.Result;
                followingCount = followingCountTask.Result;
                followers = followersTask.Result;
                following = followingTask.Result;

                isOwnProfile = currentUserId == profile.Id;
                editDisplayName = profile.DisplayName;
                editBio = profile.Bio ?? "";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            profile = null;
        }
        finally
        {
            isLoaded = true;
        }
    }

    private void EditMode() => isEditing = !isEditing;

    private async Task ToggleFollow()
    {
        if (profile == null) return;

        if (isFollowing)
        {
            await FollowService.UnFollowAsync(profile.Id);
            isFollowing = false;
            followersCount--;
        }
        else
        {
            await FollowService.FollowAsync(profile.Id);
            isFollowing = true;
            followersCount++;
        }

        followers = await FollowService.GetFollowersAsync(profile.Id);
    }

    private async Task SaveProfile()
    {
        var token = await LocalStorage.GetItemAsync("token");
        var request = new HttpRequestMessage(HttpMethod.Put, "api/Users/me");
        request.Headers.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        request.Content = JsonContent.Create(new
        {
            DisplayName = editDisplayName,
            Bio = editBio
        });

        var response = await Http.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            profile!.DisplayName = editDisplayName;
            profile!.Bio = editBio;
            isEditing = false;
            StateHasChanged();
        }
    }

    private async Task LikePost(PostDto post)
    {
        var result = await PostService.ToggleLikeAsync(post.Id);
        if (result)
        {
            if (post.IsLikedByCurrentUser)
            {
                post.LikesCount--;
                post.IsLikedByCurrentUser = false;
            }
            else
            {
                post.LikesCount++;
                post.IsLikedByCurrentUser = true;
            }
            StateHasChanged();
        }
    }

    private async Task OpenComments(PostDto post)
    {
        if (selectedPostId == post.Id)
        {
            selectedPostId = null;
            return;
        }
        selectedPostId = post.Id;
        comments = await PostService.GetCommentsAsync(post.Id) ?? new();
    }

    private async Task AddComment(Guid postId)
    {
        if (string.IsNullOrWhiteSpace(commentText)) return;
        var result = await PostService.AddCommentAsync(postId, commentText);
        if (result)
        {
            commentText = "";
            comments = await PostService.GetCommentsAsync(postId) ?? new();
        }
    }

    private async Task HandleCommentKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && selectedPostId != null)
            await AddComment(selectedPostId.Value);
    }

    private async Task DeletePost(Guid postId)
    {
        var result = await PostService.DeletePostAsync(postId);
        if (result)
        {
            posts = posts.Where(p => p.Id != postId).ToList();
            StateHasChanged();
        }
    }
}