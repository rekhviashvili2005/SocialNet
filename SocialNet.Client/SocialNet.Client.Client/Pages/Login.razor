@page "/login"
@rendermode InteractiveWebAssembly
@using SocialNet.Client.Client.Services
@inject AuthService AuthService
@inject LocalStorageService LocalStorage
@inject NavigationManager Navigation

<h3>შესვლა</h3>

<div>
    <input @bind="email" placeholder="Email" type="email" />
</div>
<div>
    <input @bind="password" placeholder="პაროლი" type="password" />
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <p style="color:red">@errorMessage</p>
}

<button @onclick="HandleLogin">შესვლა</button>
<br />
<a href="/register">ანგარიში არ გაქვს? დარეგისტრირდი!</a>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";
    private bool isReady = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var token = await LocalStorage.GetItemAsync("token");
            if (token != null)
            {
                Navigation.NavigateTo("/feed");
            }
            isReady = true;
            StateHasChanged();
        }
    }

    private async Task HandleLogin()
    {
        if (!isReady) return;

        errorMessage = "";
        var token = await AuthService.LoginAsync(email, password);

        if (token == null)
        {
            errorMessage = "Email ან პაროლი არასწორია!";
            return;
        }

        await LocalStorage.SetItemAsync("token", token);
        Navigation.NavigateTo("/feed", forceLoad: true);
    }
}